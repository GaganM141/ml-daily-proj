   "source": [
    "s=input('enter a string: ')\n",
    "c=''\n",
    "for i in s:\n",
    "    if ('a'<=i<='z' or 'A'<=i<='Z') and i not in 'AEIOUaeiou':\n",
    "        c+=i\n",
    "print(c)\n",
    "        "
